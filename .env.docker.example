# =============================================================================
#  Omnia — Dokploy / Docker Compose environment template
#
#  Copy these values into the Dokploy UI → your application → Environment tab.
#  Dokploy will write them to a .env file in the repo root at deploy time,
#  and docker-compose will substitute them into the compose file automatically.
#
#  Do NOT commit a filled-in .env file — real values belong in Dokploy's UI.
# =============================================================================

# --- Domains (Traefik Host() rules) ------------------------------------------
# Public frontend
DOMAIN=omnia.example.com
# Public SpacetimeDB WebSocket endpoint
DB_DOMAIN=db.omnia.example.com

# --- Client build-time config ------------------------------------------------
# MUST be the wss:// URL of DB_DOMAIN (baked into the Vite bundle at build time)
VITE_SPACETIMEDB_HOST=wss://db.omnia.example.com
# Database / module name registered on the self-hosted SpacetimeDB
VITE_SPACETIMEDB_DB_NAME=omnia
