# =============================================================================
#  Omnia — local environment template
#
#  Copy to .env.local and fill in your values:
#    cp .env.local.example .env.local
#
#  .env.local is gitignored and never committed.
# =============================================================================

# ── SpacetimeDB ──────────────────────────────────────────────────────────────
# Use maincloud for production, ws://localhost:3000 for local spacetime start
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=your-database-name

# ── AI bot (only needed when running ai-bot/) ─────────────────────────────────
# LLM provider: 'gemini' (free tier) or 'openai'
AI_PROVIDER=gemini

# Qdrant vector database
QDRANT_URL=https://qdrant.example.com
QDRANT_API_KEY=
QDRANT_COLLECTION=omnia_messages

# Google Gemini (AI_PROVIDER=gemini)
GOOGLE_GENERATIVE_AI_API_KEY=

# OpenAI (AI_PROVIDER=openai)
# OPENAI_API_KEY=

# Optional bot identity token (leave blank — auto-minted on first run)
OMNIA_BOT_TOKEN=
