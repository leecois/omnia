# =============================================================================
#  Omnia AI bot — environment template
#
#  In development, the bot inherits everything from ../.env.local via the
#  `--env-file=../.env.local` flag in package.json scripts. This file exists
#  for production deploys where the bot runs in its own container without
#  access to the frontend's env file.
# =============================================================================

# ── SpacetimeDB ──────────────────────────────────────────────────
# Same host and database name the frontend uses.
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
VITE_SPACETIMEDB_DB_NAME=your-database-name

# Persisted bot identity. Leave blank on first run; the bot will mint a
# fresh identity, write the token to .bot-token, and reuse it next time.
OMNIA_BOT_TOKEN=
OMNIA_BOT_TOKEN_PATH=./.bot-token

# ── Qdrant vector store ──────────────────────────────────────────
QDRANT_URL=https://qdrant.example.com
QDRANT_API_KEY=
QDRANT_COLLECTION=omnia_messages
# Optional — defaults to 1536. Both providers are forced to this width.
QDRANT_VECTOR_SIZE=1536

# ── LLM provider selection ───────────────────────────────────────
# 'openai' or 'gemini'
AI_PROVIDER=gemini

# --- OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ── Behaviour knobs ──────────────────────────────────────────────
# How many top hits to pass to the LLM as context
AI_TOP_K=8
# Hard cap on total characters fed to the LLM
AI_MAX_CONTEXT_CHARS=6000
# Delay between ingestion chunks, ms
AI_INGEST_BACKOFF_MS=250
