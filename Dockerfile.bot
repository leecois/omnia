# syntax=docker/dockerfile:1.7

# =============================================================================
#  Omnia AI Bot — Dockerfile
#
#  Long-running Bun process that subscribes to SpacetimeDB, indexes messages
#  in Qdrant, and answers /ask questions via Gemini or OpenAI.
#
#  Built from the repo root because ai-bot imports ../src/module_bindings.
# =============================================================================

FROM oven/bun:1.2-debian
WORKDIR /app

# 1. Install root deps (module_bindings need the spacetimedb package).
COPY package.json bun.lock ./
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --production

# 2. Install bot deps.
COPY ai-bot/package.json ai-bot/bun.lock* ai-bot/
RUN --mount=type=cache,target=/root/.bun/install/cache \
    cd ai-bot && bun install --frozen-lockfile --production

# 3. Copy only what the bot needs at runtime.
COPY src/module_bindings/ src/module_bindings/
COPY ai-bot/src/ ai-bot/src/
COPY ai-bot/tsconfig.json ai-bot/

WORKDIR /app/ai-bot

CMD ["bun", "run", "src/index.ts"]
